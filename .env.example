# QRMenu SaaS — Environment Variables
# Copy this file to .env and fill in your values

# Flask secret key (change this in production!)
SECRET_KEY=your-random-secret-key-here-change-me

# Database URL
# For local development with SQLite:
# DATABASE_URL=sqlite:///dev.db
# For PostgreSQL (Railway/production):
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Web Push VAPID Keys (optional — for push notifications)
# Generate with: python -c "from pywebpush import vapid_generate; k=vapid_generate(); print(k['public_key']); print(k['private_key'])"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@qrmenu.om

# Flask environment
FLASK_ENV=development
